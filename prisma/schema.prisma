generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String?
  passwordHash       String?
  role               Role      @default(USER)
  mustChangePassword Boolean   @default(true)
  offers             Offer[]
  requests           Request[]
  createdAt          DateTime  @default(now())
  reports            Report[]
  routines           Routine[]
}
model Request {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id])
  vin        String?
  text       String
  source     RequestSource
  status     RequestStatus   @default(NEW)
  tags       String[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  actions    RequestAction[]
  resolvedAt DateTime?
}

enum RequestSource {
  INTERNATIONAL
  CUSTOMER_SERVICE
}

enum RequestStatus {
  NEW
  CALLED_NO_ANSWER
  RESOLVED
}

enum Role {
  ADMIN
  USER
}

model Offer {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  vin           String
  make          String?
  model         String?
  year          String?
  price         String
  lotNumber     String?
  pickupPlace   String?
  deliveryPlace String?
  recipients    OfferRecipient[]
  createdAt     DateTime         @default(now())
}

model OfferRecipient {
  id          String   @id @default(cuid())
  offerId     String
  offer       Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  companyName String
  phone       String
  createdAt   DateTime @default(now())
}

model Warehouse {
  id        String   @id @default(cuid())
  code      String   @unique
  city      String?
  address   String
  createdAt DateTime @default(now())
}
model RequestAction {
  id        String            @id @default(cuid())
  requestId String
  request   Request           @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId    String
  source    RequestSource
  type      RequestActionType
  createdAt DateTime          @default(now())
}

enum RequestActionType {
  CALLED_NO_ANSWER
  TEXTED
  RESOLVED
}
model Report {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  date      String
  blocks    ReportBlock[]
  createdAt DateTime      @default(now())

  @@unique([userId, date])
}

model ReportBlock {
  id          String        @id @default(cuid())
  reportId    String
  report      Report        @relation(fields: [reportId], references: [id], onDelete: Cascade)
  section     ReportSection
  kind        BlockKind     @default(MANUAL)
  text        String
  vin         String?
  sortOrder   Int           @default(0)
  carriedFrom String?
  createdAt   DateTime      @default(now())
}

model Routine {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  text      String
  sections  ReportSection[]
  active    Boolean         @default(true)
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
}

enum ReportSection {
  DONE
  PLAN
  BLOCKERS
}

enum BlockKind {
  MANUAL
  AUTO
  ROUTINE
}
